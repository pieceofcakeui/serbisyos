Options -Indexes
RewriteEngine On

# Set the base directory for all rules
RewriteBase /
RewriteRule ^account/backend/ - [L]
RewriteRule ^admin/backend/ - [L]
RewriteRule ^home$ index.php [L]
RewriteRule ^verify_otp_reset/?$ verify_otp_reset.php [L,QSA]
RewriteRule ^verify_otp/?$ verify_otp.php [L,QSA]

# --- CUSTOM ERROR PAGES ---
ErrorDocument 403 /error.php?code=403
ErrorDocument 404 /error.php?code=404
ErrorDocument 500 /error.php?code=500

# --- SEO & USER-FRIENDLY REWRITES ---
# Public Access
RewriteRule ^service(?:/([a-zA-Z0-9-]+))?/?$ service.php?slug=$1 [L,QSA]
RewriteRule ^emergency-help(?:/([a-zA-Z0-9-]+))?/?$ emergency-help.php?service_slug=$1 [L,QSA]
RewriteRule ^shop/([a-zA-Z0-9-]+)/?$ view_detail.php?shop=$1 [L,QSA]
RewriteRule ^search(?:/([a-zA-Z0-9-]+))?/?$ search.php?service_slug=$1 [L,QSA]

#Private Access
RewriteRule ^account/emergency-help(?:/([a-zA-Z0-9-]+))?/?$ account/emergency-help.php?service_slug=$1 [L,QSA]
RewriteRule ^account/service(?:/([a-zA-Z0-9-]+))?/?$ account/service.php?slug=$1 [L,QSA]
RewriteRule ^account/search(?:/([a-zA-Z0-9-]+))?/?$ account/search.php?service_slug=$1 [L,QSA]
RewriteRule ^account/shop/([a-zA-Z0-9-]+)/?$ account/view_details.php?shop=$1 [L,QSA]
RewriteRule ^account/shop/([a-zA-Z0-9-]+)$ account/emergency-requests.php?shop=$1 [QSA,L]


